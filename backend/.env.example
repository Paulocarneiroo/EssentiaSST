# ─── Servidor ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Banco de dados (PostgreSQL) ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=essentiasst
DB_USER=essentiasst
DB_PASSWORD=changeme

# String de conexão usada pelo Prisma (deve refletir as variáveis DB_* acima)
DATABASE_URL="postgresql://essentiasst:changeme@localhost:5432/essentiasst?schema=public"

# ─── Autenticação (uso futuro) ────────────────────────────────────────────
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=1d
